{
  "name": "video-crop-tool",
  "version": "6.0.0",
  "description": "Studio-grade video crop tool",
  "author": "Your Name",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish=never"
  },
  "build": {
    "appId": "com.videocrop.tool",
    "productName": "Video Crop Tool",
    "directories": { "output": "dist" },
    "files": ["**/*"],
    "extraResources": [
      { "from": "resources/mpv", "to": "mpv" }
    ],
    "win": { "target": "nsis" },
    "npmRebuild": false
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.2",
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
