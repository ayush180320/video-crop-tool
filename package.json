{
  "name": "video-crop-tool",
  "version": "1.0.0",
  "description": "Video crop detection tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.videocrop.tool",
    "productName": "Video Crop Tool",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "backend/**/*",
      "public/**/*",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "electron": "^28.0.0",
    "fluent-ffmpeg": "^2.1.2",
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  }
}
